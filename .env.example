# =============================================================================
# CharacterGeneration — Environment Configuration Template
# Copy this file to .env and fill in your values.
# This template IS committed to git. The actual .env is git-ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (FastAPI / Uvicorn)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# -----------------------------------------------------------------------------
# Frontend (Vite / React)
# -----------------------------------------------------------------------------
VITE_PORT=5173
VITE_BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Ollama — Local LLM
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
# Replace with the model you have pulled: ollama pull <model>
OLLAMA_MODEL=your_model_name:latest

# Choose your provider: "ollama", "openai", "anthropic", or "gemini"
LLM_PROVIDER=ollama
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Optional overrides for different API endpoints (e.g., LM Studio, vLLM)
# OPENAI_BASE_URL=http://localhost:1234/v1
# ANTHROPIC_BASE_URL=http://localhost:8080/v1

# -----------------------------------------------------------------------------
# Embeddings (HuggingFace / sentence-transformers)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RAG_TOP_K=6

# -----------------------------------------------------------------------------
# ChromaDB — Vector Store
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR_PREFIX=chroma_db

# -----------------------------------------------------------------------------
# ComfyUI — Image Generation
# -----------------------------------------------------------------------------
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_POLL_LIMIT=100
COMFYUI_POLL_INTERVAL=2

# -----------------------------------------------------------------------------
# API Keys (add as needed)
# -----------------------------------------------------------------------------
# GOOGLE_API_KEY=your_google_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
