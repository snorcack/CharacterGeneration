# LLM provider configuration
# Copy this file to .env and set values for your provider.
# If no .env file exists, the app defaults to Ollama on localhost:11434.

# --- Ollama (default, no .env needed) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=Gemma4E4B:latest

# --- LMStudio ---
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=<model-identifier-shown-in-lmstudio-server-panel>
